<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fundo_pagina">


    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/azul_primario"
        app:titleTextColor="@color/branco"
        app:subtitleTextColor="#B0C4DE" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/azul_primario"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:paddingBottom="20dp">

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_avatar"
                    android:layout_marginEnd="14dp">
                    <TextView
                        android:id="@+id/tv_iniciais_avatar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textColor="@color/branco"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:text="JS" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tv_nome_aluno"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nome do Aluno"
                        android:textColor="@color/branco"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tv_curso"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Curso · Semestre"
                        android:textColor="#B0C4DE"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />
                    <TextView
                        android:id="@+id/tv_data"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Data atual"
                        android:textColor="#8090A8"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">


                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/branco">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">
                        <FrameLayout
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@drawable/bg_empresa_icon"
                            android:layout_marginEnd="12dp">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_building"
                                android:tint="@color/azul_primario" />
                        </FrameLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tv_empresa"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Empresa"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/texto_principal" />
                            <TextView
                                android:id="@+id/tv_endereco_empresa"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Endereço"
                                android:textSize="12sp"
                                android:textColor="@color/cinza_texto"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                        <com.google.android.material.chip.Chip
                            android:id="@+id/tv_turno"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Manhã"
                            android:textSize="11sp"
                            app:chipBackgroundColor="#E3F0FF"
                            android:textColor="@color/azul_primario" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>


                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_localizacao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/branco">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SUA LOCALIZAÇÃO"
                            android:textSize="11sp"
                            android:textColor="@color/cinza_texto"
                            android:letterSpacing="0.08"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <ImageView
                                android:id="@+id/iv_status_loc"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_status_amarelo"
                                android:layout_marginEnd="10dp" />
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:id="@+id/tv_localizacao"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Obtendo localização..."
                                    android:textSize="13sp"
                                    android:textColor="@color/texto_principal" />
                                <TextView
                                    android:id="@+id/tv_coordenadas"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text=""
                                    android:textSize="11sp"
                                    android:textColor="@color/cinza_texto"
                                    android:fontFamily="monospace"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>


                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/branco">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MAPA"
                            android:textSize="11sp"
                            android:textColor="@color/cinza_texto"
                            android:letterSpacing="0.08"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />
                        <fragment
                            android:id="@+id/map"
                            android:name="com.google.android.gms.maps.SupportMapFragment"
                            android:layout_width="match_parent"
                            android:layout_height="220dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>


                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/branco">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="STATUS DE HOJE"
                                android:textSize="11sp"
                                android:textColor="@color/cinza_texto"
                                android:letterSpacing="0.08"
                                android:textStyle="bold"
                                android:layout_weight="1" />
                            <TextView
                                android:id="@+id/tv_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Aguardando localização..."
                                android:textSize="13sp"
                                android:textColor="@color/cinza_texto"
                                android:textStyle="bold" />
                        </LinearLayout>
                        <Button
                            android:id="@+id/btn_checkin"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:text="Registrar Check-in"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:backgroundTint="@color/verde_confirmacao"
                            android:enabled="false" />
                        <Button
                            android:id="@+id/btn_checkout"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:text="Registrar Check-out"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:backgroundTint="@color/vermelho_checkout"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>