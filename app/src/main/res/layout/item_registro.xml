<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/branco">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- Indicador lateral colorido -->
        <View
            android:id="@+id/view_indicador"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="12dp"
            android:minHeight="48dp"
            android:background="@color/verde_confirmacao" />

        <!-- Ícone -->
        <ImageView
            android:id="@+id/iv_icone_registro"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_checkin" />

        <!-- Informações -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_tipo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Check-in"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/verde_confirmacao" />

            <TextView
                android:id="@+id/tv_endereco_registro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="@color/cinza_texto"
                android:layout_marginTop="2dp"
                android:maxLines="2" />

            <TextView
                android:id="@+id/tv_coordenadas_registro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="lat, lng"
                android:textSize="11sp"
                android:textColor="@color/cinza_texto"
                android:fontFamily="monospace"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Horário e Data -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tv_horario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00:00"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/texto_principal"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tv_data_registro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00/00/0000"
                android:textSize="11sp"
                android:textColor="@color/cinza_texto"
                android:layout_marginTop="2dp" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
